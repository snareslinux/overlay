pkgname=snares-dinit-services
version=0.1.0
revision=1
short_desc="Snares Linux dinit service files"
maintainer="Wilgot"
license="MIT"
homepage="https://snareslinux.github.io"

depends="snares-dinit NetworkManager apparmor grub"

do_install() {
	
	vmkdir etc/dinit.d
	
	vcopy ${FILESDIR}/NetworkManager etc/dinit.d/NetworkManager
	vcopy ${FILESDIR}/apparmor etc/dinit.d/apparmor
	vcopy ${FILESDIR}/grub-update etc/dinit.d/grub-update
	vcopy ${FILESDIR}/tty1 etc/dinit.d/tty1
	vcopy ${FILESDIR}/dbus etc/dinit.d/dbus
	vcopy ${FILESDIR}/snares.target etc/dinit.d/snares.target

	vmkdir etc/dinit.d/boot.d
	vmkdir usr/libexec/snares

	vcopy ${FILESDIR}/dbus-start usr/libexec/snares/dbus-start
	chmod 755 ${DESTDIR}/usr/libexec/snares/dbus-start

	ln -sf ../dbus ${DESTDIR}/etc/dinit.d/boot.d/dbus
	ln -sf ../NetworkManager ${DESTDIR}/etc/dinit.d/boot.d/NetworkManager
	ln -sf ../tty1 ${DESTDIR}/etc/dinit.d/boot.d/tty1

	ln -sf snares.target ${DESTDIR}/etc/dinit.d/boot
}
